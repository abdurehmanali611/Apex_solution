.env*

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Debug logs ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python / Django ───────────────────────────────────────────
