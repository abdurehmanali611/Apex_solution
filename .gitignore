/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────
/.next/
/out/
/build

# ── Testing ───────────────────────────────────────────────────
/coverage

